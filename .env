# ── Database Configuration ──────────────────────────────────────────────────
# Local SQLite is used if DATABASE_URL is not set.
# For production (PostgreSQL), set DATABASE_URL in Render.
POSTGRES_DB=quiz_db
POSTGRES_USER=quiz_user
POSTGRES_PASSWORD=quiz_password

# ── Django Backend Configuration ─────────────────────────────────────────────
SECRET_KEY=django-insecure-docker-dev-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend,.render.com

# ── CORS & Security ─────────────────────────────────────────────────────────
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Superuser Credentials (for build.sh) ────────────────────────────────────
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin123

# ── Frontend Configuration ──────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
